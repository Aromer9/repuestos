# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
# Obtén la URI en: Atlas > Connect > Drivers > Python
MONGODB_URI=mongodb+srv://<usuario>:<contraseña>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DATABASE_NAME=argparts

# ── Anthropic Claude (OpenClaw) ────────────────────────────────────────────────
# Obtén tu API key en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Meta WhatsApp Cloud API ────────────────────────────────────────────────────
# Pasos para obtener estas credenciales:
# 1. Ir a https://developers.facebook.com y crear una app de tipo "Business"
# 2. Agregar el producto "WhatsApp" a la app
# 3. En WhatsApp > API Setup encontrarás el Phone Number ID y el Token temporal
# 4. Para producción, generar un System User Token permanente en Meta Business Suite

# Token de acceso (temporal 24h en dev, permanente en producción)
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxx

# ID del número de teléfono de WhatsApp Business
WHATSAPP_PHONE_ID=1234567890

# Token para verificar el webhook (puedes elegir cualquier string secreto)
WHATSAPP_VERIFY_TOKEN=argparts_webhook_2026
