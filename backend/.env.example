# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
# Obtén la URI en: Atlas > Connect > Drivers > Python
MONGODB_URI=mongodb+srv://<usuario>:<contraseña>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DATABASE_NAME=argparts

# ── JWT Auth ───────────────────────────────────────────────────────────────────
# String secreto para firmar tokens JWT (usa: openssl rand -hex 32)
SECRET_KEY=cambia_esto_por_un_string_largo_y_aleatorio

# ── OpenAI (OpenClaw) ──────────────────────────────────────────────────────────
OPEN_AI_API_KEY=sk-...

# ── CORS Frontend (Railway) ────────────────────────────────────────────────────
# URL pública del frontend en Railway
FRONTEND_URL=https://tu-frontend.up.railway.app

# ── Evolution API (WhatsApp open source) ──────────────────────────────────────
# Docs: https://doc.evolution-api.com
# Deploy en Railway: https://railway.app/template/evolution-api
#
# Pasos:
# 1. Deploy del template Evolution API en Railway
# 2. En el panel de Evolution API crear una instancia con el nombre "argparts"
# 3. Escanear el QR con el teléfono de la empresa
# 4. Configurar el webhook apuntando a: https://tu-backend.railway.app/api/webhook/whatsapp
# 5. Completar las variables de abajo

# URL pública de tu instancia de Evolution API en Railway
EVOLUTION_API_URL=https://tu-evolution.up.railway.app

# API Key global (se define al desplegar, variable AUTHENTICATION_API_KEY)
EVOLUTION_API_KEY=tu_api_key_secreta

# Nombre de la instancia creada en Evolution API
EVOLUTION_INSTANCE=argparts
